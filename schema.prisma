generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tunnel {
  id             String   @id @default(cuid())
  name           String
  type           String   // "local" | "remote" | "dynamic"
  status         String   @default("stopped") // "stopped" | "starting" | "active" | "error"
  technique      String?  // "chisel" | "ligolo" | "dns" | "icmp" | "wstunnel" | "frp" | "quic" | "proxyjump"
  command        String?  // raw command for technique execution
  
  // SSH Connection
  sshHost        String
  sshPort        Int      @default(22)
  sshUser        String
  sshKeyPath     String?
  sshPassword    String?
  
  localBindAddr  String   @default("127.0.0.1")
  localPort      Int
  remoteBindAddr String?
  remotePort     Int?
  
  pid            Int?
  errorMessage   String?
  startedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Deployment {
  id              String   @id @default(cuid())
  name            String
  status          String   @default("pending") // pending | deploying | active | error | removed

  // Target machine (behind NAT)
  targetHost      String
  targetPort      Int      @default(22)
  targetUser      String
  targetPassword  String?
  targetKeyPath   String?

  // VPS (public server)
  vpsHost         String
  vpsPort         Int      @default(22)
  vpsUser         String   @default("tunneluser")
  vpsPassword     String?
  vpsKeyPath      String?

  // Tunnel config
  remotePort      Int      @default(2222)
  localPort       Int      @default(22)

  // Options
  serviceName     String   @default("network-connectivity")
  camouflage      Boolean  @default(true)
  ipQosBackground Boolean  @default(false)

  // Runtime
  sshPublicKey    String?
  errorMessage    String?
  currentPhase    String?  // vps-prepare | target-prepare | key-exchange | service-install | verify | complete
  deployedAt      DateTime?
  lastSeen        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
